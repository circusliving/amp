{
  "name": "amp",
  "version": "2.0.0",
  "description": "Circus Living",
  "author": "Randy Houlahan <randy@houlahan.ca>",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "generate": "nuxt generate",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "typecheck": "nuxt prepare && vue-tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@nuxt/image": "2.0.0",
    "@nuxtjs/i18n": "10.2.3",
    "@pinia/nuxt": "0.11.3",
    "@popperjs/core": "2.11.8",
    "bootstrap": "5.3.8",
    "graphql": "16.12.0",
    "graphql-request": "7.4.0",
    "luxon": "3.7.2",
    "nuxt": "4.3.1",
    "pinia": "3.0.4",
    "pluralize": "8.0.0",
    "string-strip-html": "13.5.3",
    "vue": "3.5.28",
    "vue-multiselect": "3.4.0",
    "vue-router": "5.0.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.1",
    "@nuxt/eslint": "1.15.1",
    "@nuxt/test-utils": "4.0.0",
    "@playwright/test": "1.58.2",
    "@types/luxon": "3.7.1",
    "@vitest/coverage-v8": "4.0.18",
    "@vue/test-utils": "2.4.6",
    "eslint": "10.0.1",
    "eslint-config-prettier": "10.1.8",
    "happy-dom": "20.7.0",
    "prettier": "3.8.1",
    "sass": "1.97.3",
    "typescript": "5.9.3",
    "vitest": "4.0.18",
    "vue-tsc": "3.2.5"
  }
}
